COMPOSE_PROJECT_NAME=swagreviewer

BACKEND_PORT=4000
FRONTEND_PORT=5173
OLLAMA_PORT=11434
FRONTEND_VITE_BACKEND_BASE_URL=http://localhost:4000

API_SERVICE_TOKEN=
GITHUB_WEBHOOK_SECRET=

RAG_ENABLED=true
RAG_MODEL_PROVIDER=ollama
RAG_OLLAMA_BASE_URL=http://ollama:11434
RAG_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
RAG_API_KEY=
RAG_API_GENERATION_MODEL=gemini-3-flash-preview
RAG_API_EVAL_GENERATION_MODEL=gemini-3-flash-preview
RAG_API_EMBED_MODEL=gemini-embedding-2-preview
# Gemini example: keep RAG_API_BASE_URL as above and paste your Gemini key into RAG_API_KEY
RAG_GENERATION_MODEL=qwen2.5-coder:7b
RAG_EVAL_GENERATION_MODEL=qwen2.5-coder:14b
RAG_EMBED_MODEL=nomic-embed-text
RAG_REPAIR_MODEL=
RAG_SUPPORTED_LANGUAGES=python,dart,swift,cpp,javascript
RAG_ENABLE_SECURITY=false
RAG_ENABLE_PERFORMANCE=true
RAG_DEFAULT_TOPK=6
RAG_MAX_HUNKS_PER_FILE=3
RAG_MAX_HOTSPOT_TASKS=8
RAG_EMBED_BATCH_SIZE=64
RAG_GENERATION_MAX_TOKENS=256
RAG_OLLAMA_TIMEOUT_SECONDS=120
RAG_BOOTSTRAP_TIMEOUT_SECONDS=900
RAG_SKIP_BOOTSTRAP=false
